#include <stdio.h>

int main() {
    int n;

    printf("Digite o tamanho dos vetores A, B e C: ");
    scanf("%d", &n);

    int A[n], B[n], C[n];

    // Ler vetor A
    printf("Digite os elementos do vetor A:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &A[i]);
    }

    // Ler vetor B
    printf("Digite os elementos do vetor B:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &B[i]);
    }

    // Ler vetor C
    printf("Digite os elementos do vetor C:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &C[i]);
    }

    // Exemplo: imprimir vetor C
    printf("Vetor C: ");
    for(int i = 0; i < n; i++) {
        printf("%d ", C[i]);
    }
    printf("\n");

    return 0;
}
